<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC
 "-//freedesktop//DTD polkit Policy Configuration 1.0//EN"
 "http://www.freedesktop.org/standards/PolicyKit/1/policyconfig.dtd">
<policyconfig>
  <vendor>restart-to-macos</vendor>
  <vendor_url>https://github.com/jtbrough/restart-to-macos</vendor_url>
  <action id="io.github.jtbrough.restart-to-macos.run-helper">
    <description>Restart to macOS</description>
    <message>Authentication is required to set the next boot target to macOS and reboot.</message>
    <defaults>
      <allow_any>no</allow_any>
      <allow_inactive>no</allow_inactive>
      <allow_active>auth_admin_keep</allow_active>
    </defaults>
    <annotate key="org.freedesktop.policykit.exec.path">@LIBEXECDIR@/restart-to-macos-helper</annotate>
    <annotate key="org.freedesktop.policykit.exec.allow_gui">true</annotate>
  </action>
</policyconfig>
